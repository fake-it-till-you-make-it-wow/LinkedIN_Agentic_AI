  "components": {
    "schemas": {
      "AdminHealth": {
        "properties": {
          "agents_total": { "type": "integer", "title": "Agents Total" },
          "agents_verified": { "type": "integer", "title": "Agents Verified" },
          "publishers_total": {
            "type": "integer",
            "title": "Publishers Total"
          },
          "publishers_verified": {
            "type": "integer",
            "title": "Publishers Verified"
          },
          "invocations_total": {
            "type": "integer",
            "title": "Invocations Total"
          },
          "invocation_error_rate": {
            "type": "number",
            "title": "Invocation Error Rate"
          },
          "reviews_total": { "type": "integer", "title": "Reviews Total" },
          "status": { "type": "string", "title": "Status" }
        },
        "type": "object",
        "required": [
          "agents_total",
          "agents_verified",
          "publishers_total",
          "publishers_verified",
          "invocations_total",
          "invocation_error_rate",
          "reviews_total",
          "status"
        ],
        "title": "AdminHealth",
        "description": "전체 시스템 상태 요약. 관리자 대시보드용."
      },
      "AgentCreate": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Name"
          },
          "description": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Description"
          },
          "skill_tags": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Skill Tags"
          },
          "endpoint_url": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Endpoint Url"
          },
          "career_projects": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Career Projects"
          },
          "publisher_id": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Publisher Id"
          },
          "version": {
            "type": "string",
            "title": "Version",
            "default": "1.0.0"
          },
          "input_schema": {
            "anyOf": [
              { "additionalProperties": true, "type": "object" },
              { "type": "null" }
            ],
            "title": "Input Schema"
          },
          "output_schema": {
            "anyOf": [
              { "additionalProperties": true, "type": "object" },
              { "type": "null" }
            ],
            "title": "Output Schema"
          },
          "verified": {
            "type": "boolean",
            "title": "Verified",
            "default": false
          },
          "star_rating": {
            "type": "number",
            "maximum": 5.0,
            "minimum": 0.0,
            "title": "Star Rating",
            "default": 0.0
          },
          "success_rate": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Success Rate",
            "default": 1.0
          },
          "avg_response_ms": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Avg Response Ms",
            "default": 1000
          },
          "total_calls": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Total Calls",
